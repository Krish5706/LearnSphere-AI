# Server Configuration
PORT=
NODE_ENV=

# Database 
# (Replace with your actual MongoDB Atlas connection string)
MONGODB_URI=
# Security
# SECRET: A random string to encrypt your tokens
JWT_SECRET=

# EXPIRES: How long the user stays logged in
JWT_EXPIRES_IN=

# AI Integration
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-pro

# File Upload Settings
MAX_FILE_SIZE=

# Email OTP (Nodemailer)
# Example for Gmail SMTP:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# MAIL_FROM=LearnSphere <no-reply@learnsphere.ai>
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
